{
  "tabWidth": 2,
  "singleQuote": false,
  "printWidth": 100,
  "semi": true,
  "jsxSingleQuote": true,
  "endOfLine": "auto",
  "trailingComma": "none",
  "arrowParens": "avoid",
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindConfig": "./tailwind.config.ts",
  "tailwindFunctions": ["clsx", "cx", "twMerge", "twMerge", "twJoin"]
}
